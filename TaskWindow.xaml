<Window x:Class="CyberSecurityChatbotP3.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Task Manager"
        Height="680" Width="800"
        Background="#0D1117"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#161B22"
                BorderBrush="#00FF9C" BorderThickness="0,0,0,2"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Fill="#00FF9C" Margin="0,0,10,0"
                         VerticalAlignment="Center"/>
                <TextBlock Text="TASK MANAGER"
                           Foreground="#00FF9C" FontSize="18"
                           FontWeight="Bold" FontFamily="Consolas"
                           VerticalAlignment="Center"/>
                <TextBlock Text="  |  Cybersecurity To-Do List"
                           Foreground="#8B949E" FontSize="12"
                           FontFamily="Consolas" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Add task form -->
        <Border Grid.Row="1" Background="#161B22"
                BorderBrush="#1C2333" BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel>
                <TextBlock Text="[ ADD NEW TASK ]"
                           Foreground="#484F58" FontSize="10"
                           FontFamily="Consolas" FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Title:"
                               Foreground="#8B949E" FontFamily="Consolas"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtTaskTitle" Grid.Column="1"
                             Background="#0D1117" Foreground="#E6EDF3"
                             CaretBrush="#00FF9C" FontSize="13"
                             Padding="8,5" BorderBrush="#30363D" BorderThickness="1"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Details:"
                               Foreground="#8B949E" FontFamily="Consolas"
                               FontSize="12" VerticalAlignment="Top"
                               Margin="0,4,0,0"/>
                    <TextBox x:Name="TxtTaskDesc" Grid.Column="1"
                             Background="#0D1117" Foreground="#E6EDF3"
                             CaretBrush="#00FF9C" FontSize="13"
                             Padding="8,5" BorderBrush="#30363D" BorderThickness="1"
                             TextWrapping="Wrap" Height="50" AcceptsReturn="True"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Remind in:"
                               Foreground="#8B949E" FontFamily="Consolas"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtReminderDays" Grid.Column="1"
                             Width="50" Background="#0D1117" Foreground="#E6EDF3"
                             CaretBrush="#00FF9C" FontSize="13"
                             Padding="8,5" BorderBrush="#30363D" BorderThickness="1"/>
                    <TextBlock Grid.Column="2" Text=" days  (leave blank for no reminder)"
                               Foreground="#484F58" FontFamily="Consolas"
                               FontSize="11" VerticalAlignment="Center"/>
                    <Button Grid.Column="4" Content="+ Add Task"
                            Background="#00FF9C" Foreground="#0D1117"
                            FontWeight="Bold" FontSize="12"
                            Padding="14,7" BorderThickness="0"
                            Cursor="Hand" Click="BtnAddTask_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Task list -->
        <Border Grid.Row="2" Background="#0D1117">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#161B22" Padding="12,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="✔" Foreground="#484F58" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Column="1" Text="TITLE" Foreground="#484F58" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Column="2" Text="DESCRIPTION" Foreground="#484F58" FontFamily="Consolas" FontSize="11"/>
                        <TextBlock Grid.Column="3" Text="REMINDER" Foreground="#484F58" FontFamily="Consolas" FontSize="11"/>
                    </Grid>
                </Border>

                <ListView x:Name="TaskListView" Grid.Row="1"
                          Background="#0D1117" BorderThickness="0"
                          SelectionMode="Single" Foreground="#E6EDF3">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="30"
                                            DisplayMemberBinding="{Binding StatusIcon}"/>
                            <GridViewColumn Header="Title" Width="200"
                                            DisplayMemberBinding="{Binding Title}"/>
                            <GridViewColumn Header="Description" Width="250"
                                            DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="Reminder" Width="155"
                                            DisplayMemberBinding="{Binding ReminderDisplay}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Action buttons -->
        <Border Grid.Row="3" Background="#161B22"
                BorderBrush="#00FF9C" BorderThickness="0,2,0,0"
                Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="✔ Mark Complete"
                        Background="#102030" Foreground="#58A6FF"
                        BorderBrush="#58A6FF" BorderThickness="1"
                        FontSize="12" FontWeight="Bold"
                        Padding="12,6" Margin="0,0,8,0"
                        Cursor="Hand" Click="BtnComplete_Click"/>
                <Button Content="🗑 Delete Task"
                        Background="#3D1010" Foreground="#FF7B72"
                        BorderBrush="#FF7B72" BorderThickness="1"
                        FontSize="12" FontWeight="Bold"
                        Padding="12,6" Margin="0,0,8,0"
                        Cursor="Hand" Click="BtnDelete_Click"/>
                <Button Content="↻ Refresh"
                        Background="#1C2333" Foreground="#00FF9C"
                        BorderBrush="#00FF9C" BorderThickness="1"
                        FontSize="12" FontWeight="Bold"
                        Padding="12,6"
                        Cursor="Hand" Click="BtnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="#010409"
                BorderBrush="#1C2333" BorderThickness="0,1,0,0"
                Padding="12,5">
            <TextBlock x:Name="TxtTaskStatus"
                       Text="Select a task to manage it."
                       Foreground="#484F58" FontSize="11"
                       FontFamily="Consolas"/>
        </Border>

    </Grid>
</Window>
<Window x:Class="CyberSecurityChatbotP3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot - Cybersecurity Assistant v3"
        Height="900" Width="1300"
        Background="#0D1117"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Original content -->
        </Grid.ColumnDefinitions>

        <!-- ==================== SIDEBAR ==================== -->
        <Border Grid.Column="0" Background="#161B22"
                BorderBrush="#00FF9C" BorderThickness="0,0,2,0">
            <StackPanel>

                <!-- Logo area -->
                <Border Background="#0D1117" Padding="16,20">
                    <StackPanel>
                        <Ellipse Width="50" Height="50"
                                 Fill="#00FF9C"
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,10"/>
                        <TextBlock Text="CYBER BOT"
                                   Foreground="#00FF9C"
                                   FontSize="16" FontWeight="Bold"
                                   FontFamily="Consolas"
                                   TextAlignment="Center"/>
                        <TextBlock Text="v3.0"
                                   Foreground="#484F58"
                                   FontSize="11" FontFamily="Consolas"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TxtUserLabel"
                                   Text="" Foreground="#8B949E"
                                   FontSize="11" FontFamily="Consolas"
                                   TextAlignment="Center"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Divider -->
                <Border Height="1" Background="#00FF9C" Margin="12,0"/>

                <!-- Features label -->
                <TextBlock Text="FEATURES"
                           Foreground="#484F58" FontSize="10"
                           FontFamily="Consolas" FontWeight="Bold"
                           Margin="16,16,0,8"/>

                <!-- Feature buttons -->
                <Button Content="📋   Task Manager"
                        Margin="10,3" Padding="12,10"
                        FontSize="12" FontWeight="Bold"
                        Background="#102030" Foreground="#58A6FF"
                        BorderBrush="#58A6FF" BorderThickness="1"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand" Click="BtnOpenTasks_Click"/>

                <Button Content="🎮   Security Quiz"
                        Margin="10,3" Padding="12,10"
                        FontSize="12" FontWeight="Bold"
                        Background="#1A1A00" Foreground="#E3B341"
                        BorderBrush="#E3B341" BorderThickness="1"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand" Click="BtnOpenQuiz_Click"/>

                <Button Content="📜   Activity Log"
                        Margin="10,3" Padding="12,10"
                        FontSize="12" FontWeight="Bold"
                        Background="#1C2333" Foreground="#8B949E"
                        BorderBrush="#8B949E" BorderThickness="1"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand" Click="BtnShowLog_Click"/>

                <Button Content="🧠   Memory Recall"
                        Margin="10,3" Padding="12,10"
                        FontSize="12" FontWeight="Bold"
                        Background="#1C2333" Foreground="#00FF9C"
                        BorderBrush="#00FF9C" BorderThickness="1"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand" Click="BtnMemory_Click"/>

                <!-- Divider -->
                <Border Height="1" Background="#00FF9C" Margin="12,12"/>

                <!-- Clear button -->
                <Button Content="🗑   Clear Chat"
                        Margin="10,3" Padding="12,10"
                        FontSize="12" FontWeight="Bold"
                        Background="#3D1010" Foreground="#FF7B72"
                        BorderBrush="#FF7B72" BorderThickness="1"
                        HorizontalContentAlignment="Left"
                        Cursor="Hand" Click="BtnClear_Click"/>

            </StackPanel>
        </Border>

        <!-- ==================== ORIGINAL CONTENT (colours unchanged) ==================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ==================== ROW 0: HEADER ==================== -->
            <Border Grid.Row="0" Background="#161B22" BorderBrush="#00FF9C"
                    BorderThickness="0,0,0,2" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="12" Height="12" Fill="#00FF9C" Margin="0,0,10,0"/>
                        <TextBlock Text="CYBER BOT"
                                   Foreground="#00FF9C" FontSize="20"
                                   FontWeight="Bold" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  |  Cybersecurity Assistant v3"
                                   Foreground="#8B949E" FontSize="13"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== ROW 1: ASCII ART ==================== -->
            <Border Grid.Row="1" Background="#0D1117"
                    BorderBrush="#1C2333" BorderThickness="0,0,0,1"
                    Padding="10,10">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#00FF9C" TextAlignment="Center"
                               Text="  ██████╗██╗   ██╗██████╗ ███████╗██████╗     ██████╗  ██████╗ ████████╗"/>
                    <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#00FF9C" TextAlignment="Center"
                               Text=" ██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗    ██╔══██╗██╔═══██╗╚══██╔══╝"/>
                    <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#00FF9C" TextAlignment="Center"
                               Text=" ██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝    ██████╔╝██║   ██║   ██║"/>
                    <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#00FF9C" TextAlignment="Center"
                               Text=" ██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗    ██╔══██╗██║   ██║   ██║"/>
                    <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#00FF9C" TextAlignment="Center"
                               Text=" ╚██████╗   ██║   ██████╔╝███████╗██║  ██║    ██████╔╝╚██████╔╝   ██║"/>
                    <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#00FF9C" TextAlignment="Center"
                               Text="  ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝    ╚═════╝  ╚═════╝    ╚═╝"/>
                    <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#484F58"
                               TextAlignment="Center" Margin="0,4,0,0"
                               Text="— Your Cybersecurity Awareness Assistant —"/>
                </StackPanel>
            </Border>

            <!-- ==================== ROW 2: FEATURE NAV BUTTONS ==================== -->
            <Border Grid.Row="2" Background="#0D1117"
                    BorderBrush="#00FF9C" BorderThickness="0,0,0,1"
                    Padding="10,8">
                <StackPanel>
                    <TextBlock Text="[ FEATURES ]"
                               Foreground="#484F58" FontSize="10"
                               FontFamily="Consolas" FontWeight="Bold"
                               Margin="0,0,0,6"/>
                    <WrapPanel Orientation="Horizontal">
                        <Button Content="📋  Task Manager"
                                Margin="3" Padding="12,7" FontWeight="Bold" FontSize="12"
                                Background="#102030" Foreground="#58A6FF"
                                BorderBrush="#58A6FF" BorderThickness="1"
                                Cursor="Hand" Click="BtnOpenTasks_Click"/>
                        <Button Content="🎮  Security Quiz"
                                Margin="3" Padding="12,7" FontWeight="Bold" FontSize="12"
                                Background="#1A1A00" Foreground="#E3B341"
                                BorderBrush="#E3B341" BorderThickness="1"
                                Cursor="Hand" Click="BtnOpenQuiz_Click"/>
                        <Button Content="📜  Activity Log"
                                Margin="3" Padding="12,7" FontWeight="Bold" FontSize="12"
                                Background="#1C2333" Foreground="#8B949E"
                                BorderBrush="#8B949E" BorderThickness="1"
                                Cursor="Hand" Click="BtnShowLog_Click"/>
                        <Button Content="🧠  Memory Recall"
                                Margin="3" Padding="12,7" FontWeight="Bold" FontSize="12"
                                Background="#102030" Foreground="#00FF9C"
                                BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="BtnMemory_Click"/>
                        <TextBlock Text=" | " Foreground="#484F58"
                                   FontSize="18" VerticalAlignment="Center" Margin="4,0"/>
                        <Button Content="Clear Chat"
                                Margin="3" Padding="12,7" FontWeight="Bold" FontSize="12"
                                Background="#3D1010" Foreground="#FF7B72"
                                BorderBrush="#FF7B72" BorderThickness="1"
                                Cursor="Hand" Click="BtnClear_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ==================== ROW 3: QUICK TOPIC BUTTONS ==================== -->
            <Border Grid.Row="3" Background="#161B22"
                    BorderBrush="#1C2333" BorderThickness="0,0,0,1"
                    Padding="10,6">
                <StackPanel>
                    <TextBlock Text="[ QUICK TOPICS ]"
                               Foreground="#484F58" FontSize="10"
                               FontFamily="Consolas" FontWeight="Bold"
                               Margin="0,0,0,5"/>
                    <WrapPanel Orientation="Horizontal">
                        <Button Content="password"       Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="phishing"       Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="privacy"        Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="malware"        Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="ransomware"     Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="wifi"           Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="2fa"            Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="encryption"     Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="firewall"       Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="vpn"            Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="scam"           Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="update"         Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="backup"         Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="antivirus"      Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                        <Button Content="identity theft" Margin="2" Padding="8,4" FontSize="11" FontWeight="Bold"
                                Background="#1C2333" Foreground="#00FF9C" BorderBrush="#00FF9C" BorderThickness="1"
                                Cursor="Hand" Click="TopicButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ==================== ROW 4: CHAT AREA ==================== -->
            <Border Grid.Row="4" Background="#0D1117"
                    BorderBrush="#1C2333" BorderThickness="1,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0D1117" Padding="12,5">
                        <TextBlock Text="[ CONVERSATION ]"
                                   Foreground="#484F58" FontSize="10"
                                   FontFamily="Consolas" FontWeight="Bold"/>
                    </Border>
                    <ScrollViewer x:Name="ChatScroller" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="12,4,12,8">
                        <StackPanel x:Name="ChatPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ==================== ROW 5: INPUT BAR ==================== -->
            <Border Grid.Row="5" Background="#161B22"
                    BorderBrush="#00FF9C" BorderThickness="0,2,0,0"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="YOU ▶ "
                               Foreground="#00FF9C" FontFamily="Consolas"
                               FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtInput" Grid.Column="1"
                             Background="#1C2333" Foreground="#E6EDF3"
                             CaretBrush="#00FF9C" FontSize="13"
                             Padding="10,7" BorderBrush="#30363D" BorderThickness="1"
                             KeyDown="TxtInput_KeyDown"/>
                    <Button Grid.Column="2" Content="  Send ▶  "
                            Background="#00FF9C" Foreground="#0D1117"
                            FontWeight="Bold" FontSize="13"
                            Padding="14,7" Margin="10,0,0,0"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnSend_Click"/>
                </Grid>
            </Border>

            <!-- ==================== ROW 6: STATUS BAR ==================== -->
            <Border Grid.Row="6" Background="#010409"
                    BorderBrush="#1C2333" BorderThickness="0,1,0,0"
                    Padding="12,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtStatus" Grid.Column="0"
                               Text="Type a message or click a feature button above."
                               Foreground="#484F58" FontSize="11" FontFamily="Consolas"/>
                    <TextBlock Grid.Column="1" Text="CyberBot v3.0"
                               Foreground="#1C2333" FontSize="11" FontFamily="Consolas"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>